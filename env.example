# Environment Variables Template
# Copy this to .env.local in the frontend directory

# React App Environment Variables
REACT_APP_API_URL=https://your-api-url.com
REACT_APP_SITE_URL=https://your-vercel-app.vercel.app

# Email Configuration (if using email services)
REACT_APP_EMAIL_SERVICE=gmail
REACT_APP_EMAIL_USER=your-email@gmail.com
REACT_APP_EMAIL_PASS=your-app-password

# Analytics (if using)
REACT_APP_GA_TRACKING_ID=GA-XXXXXXXXX

# Development/Production
NODE_ENV=production
GENERATE_SOURCEMAP=false

# Vercel Specific
VERCEL_ENV=production
VERCEL_URL=your-vercel-app.vercel.app

# Optional: Backend Configuration
BACKEND_URL=https://your-backend-url.com
API_ENDPOINT=https://api.your-domain.com

# Health Check (if enabled)
ENABLE_HEALTH_CHECK=false

# Theme Configuration
DEFAULT_THEME=light
ALLOW_THEME_TOGGLE=true
